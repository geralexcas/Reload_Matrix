# Backend
SECRET_KEY=change-me-with-openssl-rand-hex-32
DATABASE_URL=postgresql://user:password@db:5432/business_db
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8080
LOG_LEVEL=INFO
UPLOAD_DIR=uploads
ENVIRONMENT=development

# Platform admin (created by scripts/init_database.py)
PLATFORM_ADMIN_EMAIL=admin@reloadmatrix.com
PLATFORM_ADMIN_USERNAME=platform_admin
PLATFORM_ADMIN_PASSWORD=AdminReload@2026
PLATFORM_ADMIN_FULL_NAME=Platform Admin

# Rate limiting (optional: set to redis://redis:6379 for multi-worker)
RATE_LIMIT_REDIS_URL=

# AI Integration
GEMINI_API_KEY=

# DIAN
DIAN_ENVIRONMENT=test
DIAN_CERT_PATH=
DIAN_CERT_PASSWORD=

# Domain (for Caddy TLS)
DOMAIN=localhost

# Database (prod: set real credentials, do NOT use defaults)
POSTGRES_DB=business_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://user:password@db:5432/business_db

# Backup offsite (S3-compatible: S3, Backblaze B2, MinIO)
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=
